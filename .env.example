# Copy this file to `.env` and fill in the values, then `docker compose up --build`.
# `.env` is gitignored — never commit real keys.

# --- agent service: LLM access via OpenRouter ---------------------------------
# REQUIRED. Create a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Optional. Any OpenRouter model slug; see https://openrouter.ai/models
# (e.g. anthropic/claude-sonnet-4.5, anthropic/claude-opus-4.1)
AGENT_MODEL=anthropic/claude-sonnet-4.5

# --- mcp_server service: openFDA access ---------------------------------------
# Optional but recommended. Free, instant key:
# https://open.fda.gov/apis/authentication/
# openFDA works without it, but a key raises the rate limits.
OPENFDA_API_KEY=
